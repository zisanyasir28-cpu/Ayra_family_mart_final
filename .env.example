# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────

# Node environment: development | production | test
NODE_ENV=development

# Express server port
PORT=5000

# Client origin — used for CORS whitelist
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────────
# AUTH / JWT
# ─────────────────────────────────────────────

# Secret for signing access tokens (min 32 chars)
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string

# Access token expiry (e.g. 15m, 1h)
JWT_ACCESS_EXPIRES_IN=15m

# Secret for signing refresh tokens (min 32 chars, different from access)
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string

# Refresh token expiry (e.g. 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# DATABASE — Supabase PostgreSQL
# ─────────────────────────────────────────────

# Prisma connection string (pooler URL for production)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Direct connection (used for migrations)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ─────────────────────────────────────────────
# REDIS — Upstash
# ─────────────────────────────────────────────

UPSTASH_REDIS_REST_URL=https://[YOUR_UPSTASH_ENDPOINT].upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_me_with_upstash_token

# ─────────────────────────────────────────────
# CLOUDINARY — Image Storage
# ─────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# ─────────────────────────────────────────────
# EMAIL — Nodemailer / Gmail SMTP
# ─────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="Superstore <no-reply@superstore.com.bd>"

# ─────────────────────────────────────────────
# PAYMENTS — SSLCommerz
# ─────────────────────────────────────────────

SSLCOMMERZ_STORE_ID=replace_me
SSLCOMMERZ_STORE_PASS=replace_me
# true = live, false = sandbox
SSLCOMMERZ_IS_LIVE=false
# Public URL of the backend — SSLCommerz uses this for IPN + redirect callbacks
# On Railway: https://your-service.up.railway.app
BACKEND_URL=https://your-backend.up.railway.app

# ─────────────────────────────────────────────
# SMS — Twilio (stubbed, optional)
# ─────────────────────────────────────────────

TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_PHONE_NUMBER=+1234567890

# ─────────────────────────────────────────────
# MONITORING — Sentry (stubbed)
# ─────────────────────────────────────────────

SENTRY_DSN=https://replace_me@sentry.io/replace_me

# ─────────────────────────────────────────────
# CLIENT (Vite — prefix with VITE_)
# ─────────────────────────────────────────────

VITE_API_URL=http://localhost:5000/api/v1
VITE_SENTRY_DSN=https://replace_me@sentry.io/replace_me
